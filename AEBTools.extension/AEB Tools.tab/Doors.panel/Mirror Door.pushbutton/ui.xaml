<!--
Tool Name    : Mirror Door Window Layout
Purpose      : Define the single-window WPF layout for scope selection, scan, results, and actions
Author       : Ajmal P.S.
Company      : AEB Tools
Version      : 1.2.4
Created      : 2026-04-22
Last Updated : 2026-04-25
Target       : Revit 2020-2027
Platform     : pyRevit / XAML
Dependencies : WPF, pyRevit window loader
Input        : User-selected scope and post-scan row selections from mirrored and unmirrored lists
Output       : Rendered single workflow window with summary, result lists, and action buttons
Notes        : Footer area is reserved for AEB Tools ownership branding on custom windows
Changelog    : v1.2.4 - Aligned metadata, naming, and release assets with the maintained workflow
License      : All Rights Reserved
Repo         : AEB-Tools
-->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Mirror Door"
    Height="900"
    Width="1260"
    MinHeight="820"
    MinWidth="1120"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    Background="#FFF7F7F5">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14" Background="#FFF1EFE6" BorderBrush="#FFD8D1B8" BorderThickness="1" CornerRadius="6">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Foreground="#FF2F3B33" Text="Mirror Door" />
                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#FF49554E"
                           Text="Scans placed host-document door instances, classifies mirrored and unmirrored doors with the real FamilyInstance.Mirrored property, and keeps scan, review, selection, and export inside one working window." />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,10" Padding="12" Background="#FFFFFFFF" BorderBrush="#FFD8D8D8" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,4" FontWeight="SemiBold" Text="Scope" />
                <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,12,0" x:Name="scopeComboBox" SelectionChanged="on_scope_changed" />
                <Button Grid.Row="1" Grid.Column="1" Width="100" Click="on_scan_click" Content="Scan" />

                <TextBlock Grid.Row="0" Grid.Column="2" Margin="18,0,8,4" FontWeight="SemiBold" Text="Total Doors Checked" />
                <TextBlock Grid.Row="0" Grid.Column="3" Margin="0,0,8,4" FontWeight="SemiBold" Text="Total Mirrored Doors" />
                <TextBlock Grid.Row="0" Grid.Column="4" Margin="0,0,0,4" FontWeight="SemiBold" Text="Total Unmirrored Doors" />

                <TextBlock Grid.Row="1" Grid.Column="2" Margin="18,3,8,0" x:Name="totalDoorsValueTextBlock" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Grid.Column="3" Margin="0,3,8,0" x:Name="mirroredDoorsValueTextBlock" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Grid.Column="4" Margin="0,3,0,0" x:Name="unmirroredDoorsValueTextBlock" TextWrapping="Wrap" />

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" FontWeight="SemiBold" Text="Applied Scope" />
                <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="12,10,8,0" x:Name="scopeValueTextBlock" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Grid.Column="3" Margin="0,10,8,0" FontWeight="SemiBold" Text="Total Skipped Doors" />
                <TextBlock Grid.Row="2" Grid.Column="4" Margin="0,10,0,0" x:Name="skippedDoorsValueTextBlock" TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="0,0,0,10" Padding="12" Background="#FFFFFFFF" BorderBrush="#FFD8D8D8" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="mirroredHeaderTextBlock" Margin="0,0,0,8" FontWeight="SemiBold" Text="Mirrored Doors (0)" />
                <DataGrid Grid.Row="1"
                          x:Name="mirroredDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Element ID" Binding="{Binding element_id}" Width="90" />
                        <DataGridTextColumn Header="Family Name" Binding="{Binding family_name}" Width="140" />
                        <DataGridTextColumn Header="Type Name" Binding="{Binding type_name}" Width="140" />
                        <DataGridTextColumn Header="Level" Binding="{Binding level_name}" Width="120" />
                        <DataGridTextColumn Header="Mark" Binding="{Binding mark}" Width="100" />
                        <DataGridTextColumn Header="Room Number" Binding="{Binding room_number}" Width="110" />
                        <DataGridTextColumn Header="Room Name" Binding="{Binding room_name}" Width="160" />
                        <DataGridTextColumn Header="Host" Binding="{Binding host_label}" Width="170" />
                        <DataGridTextColumn Header="Status" Binding="{Binding mirrored_status}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="0,0,0,10" Padding="12" Background="#FFFFFFFF" BorderBrush="#FFD8D8D8" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="unmirroredHeaderTextBlock" Margin="0,0,0,8" FontWeight="SemiBold" Text="Unmirrored Doors (0)" />
                <DataGrid Grid.Row="1"
                          x:Name="unmirroredDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Element ID" Binding="{Binding element_id}" Width="90" />
                        <DataGridTextColumn Header="Family Name" Binding="{Binding family_name}" Width="140" />
                        <DataGridTextColumn Header="Type Name" Binding="{Binding type_name}" Width="140" />
                        <DataGridTextColumn Header="Level" Binding="{Binding level_name}" Width="120" />
                        <DataGridTextColumn Header="Mark" Binding="{Binding mark}" Width="100" />
                        <DataGridTextColumn Header="Room Number" Binding="{Binding room_number}" Width="110" />
                        <DataGridTextColumn Header="Room Name" Binding="{Binding room_name}" Width="160" />
                        <DataGridTextColumn Header="Host" Binding="{Binding host_label}" Width="170" />
                        <DataGridTextColumn Header="Status" Binding="{Binding mirrored_status}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Padding="12" Background="#FFFFFFFF" BorderBrush="#FFD8D8D8" BorderThickness="1" CornerRadius="6">
            <TextBlock x:Name="summaryNoteTextBlock" TextWrapping="Wrap" Foreground="#FF5A5A5A" />
        </Border>

        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="resultStatusTextBlock" VerticalAlignment="Center" Foreground="#FF6A5F43" TextWrapping="Wrap" />
            <Button Grid.Column="1" x:Name="selectMirroredButton" Width="150" Margin="12,0,10,0" Click="on_select_mirrored_click" Content="Select Mirrored in Model" />
            <Button Grid.Column="2" x:Name="selectUnmirroredButton" Width="165" Margin="0,0,10,0" Click="on_select_unmirrored_click" Content="Select Unmirrored in Model" />
            <Button Grid.Column="3" x:Name="exportReportButton" Width="170" Margin="0,0,10,0" Click="on_export_report_click" Content="Export Full Report to Excel" />
            <Button Grid.Column="4" Width="92" IsCancel="True" Click="on_close_click" Content="Close" />
        </Grid>

        <Border Grid.Row="6" Margin="0,12,0,0" Padding="0,10,0,0" BorderBrush="#FFE2DED1" BorderThickness="0,1,0,0">
            <TextBlock x:Name="brandingFooterTextBlock"
                       HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="#FF7A7467"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
