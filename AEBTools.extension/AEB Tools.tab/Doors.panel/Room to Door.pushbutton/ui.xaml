<!--
Tool Name    : Room to Door Window Layout
Purpose      : Define the WPF layout for the door parameter assignment command window
Author       : Ajmal P.S.
Company      : AEB Tools
Version      : 1.0.1
Created      : 2026-04-25
Last Updated : 2026-04-25
Target       : Revit 2020-2027
Platform     : pyRevit / XAML
Dependencies : WPF, pyRevit window loader
Input        : User-selected tool settings and preview content
Output       : Rendered tool window layout with branded footer placement
Notes        : Footer area is reserved for AEB Tools ownership branding on custom windows
Changelog    : v1.0.1 - Cleaner suffix and overwrite layout, simpler labels
License      : All Rights Reserved
Repo         : AEB-Tools
-->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Room to Door"
    Height="660"
    Width="720"
    MinHeight="600"
    MinWidth="660"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    Background="#FFF7F7F5">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="14" Background="#FFF1EFE6" BorderBrush="#FFD8D1B8" BorderThickness="1" CornerRadius="6">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Foreground="#FF2F3B33" Text="Room to Door" />
                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#FF49554E"
                           Text="Writes the room number from the chosen side of each door into a writable text door parameter. A suffix is added only when more than one door belongs to the same room number." />
            </StackPanel>
        </Border>

        <!-- Scope / Parameter / Room Side -->
        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,4" FontWeight="SemiBold" Text="Scope" />
            <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,12,0" x:Name="scopeComboBox" SelectionChanged="on_scope_changed" />

            <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,12,4" FontWeight="SemiBold" Text="Door Parameter" />
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,12,0" x:Name="parameterComboBox" SelectionChanged="on_settings_changed" />

            <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,0,4" FontWeight="SemiBold" Text="Room Side" />
            <ComboBox Grid.Row="1" Grid.Column="2" x:Name="roomSideComboBox" SelectionChanged="on_settings_changed" />
        </Grid>

        <!-- Options panel: suffix + separator + overwrite -->
        <Border Grid.Row="2" Margin="0,14,0,0" Padding="14" Background="#FFFFFFFF" BorderBrush="#FFD8D8D8" BorderThickness="1" CornerRadius="6">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Margin="0,0,0,8" Text="Suffix Options" />
                <CheckBox x:Name="suffixCheckBox"
                          Content="Add a suffix when more than one door shares the same room number"
                          Checked="on_settings_changed" Unchecked="on_settings_changed" />

                <Grid Margin="22,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0" Text="Style:" />
                    <RadioButton Grid.Column="1" x:Name="numericRadioButton" Margin="0,0,16,0"
                                 GroupName="SuffixMode" VerticalAlignment="Center"
                                 Content="Numeric (1, 2, 3...)" Checked="on_settings_changed" />
                    <RadioButton Grid.Column="2" x:Name="alphabeticRadioButton"
                                 GroupName="SuffixMode" VerticalAlignment="Center"
                                 Content="Alphabetic (A, B, C...)" Checked="on_settings_changed" />
                    <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="24,0,8,0" Text="Separator:" />
                    <TextBox Grid.Column="5" x:Name="separatorTextBox"
                             Width="70" MaxLength="20" VerticalAlignment="Center"
                             TextChanged="on_settings_changed" />
                </Grid>

                <Border Margin="0,14,0,0" Padding="0,10,0,0" BorderBrush="#FFE6E2D6" BorderThickness="0,1,0,0">
                    <CheckBox x:Name="overwriteExistingCheckBox"
                              Content="Overwrite the existing parameter value when it already has text"
                              Checked="on_settings_changed" Unchecked="on_settings_changed" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Preview -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Margin="0,0,0,6" FontWeight="SemiBold" Text="Preview Summary" />
            <TextBox Grid.Row="1"
                     x:Name="previewTextBox"
                     Padding="10"
                     Background="#FFFFFFFF"
                     BorderBrush="#FFD8D8D8"
                     BorderThickness="1"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AcceptsReturn="True" />
            <TextBlock Grid.Row="2" x:Name="statusTextBlock" Margin="0,8,0,0" Foreground="#FF6A5F43" TextWrapping="Wrap" />
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#FF5A5A5A"
                       Text="Run only writes the doors counted as Doors to update in the preview." />
            <Button Grid.Column="1" x:Name="runButton" Width="110" Margin="0,0,10,0"
                    IsDefault="True" Click="on_run_click" Content="Run Update" />
            <Button Grid.Column="2" Width="92" IsCancel="True" Click="on_cancel_click" Content="Cancel" />
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="5" Margin="0,12,0,0" Padding="0,10,0,0" BorderBrush="#FFE2DED1" BorderThickness="0,1,0,0">
            <TextBlock x:Name="brandingFooterTextBlock"
                       HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="#FF7A7467"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
